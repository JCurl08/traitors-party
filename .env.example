# Copy this file to .env (or .env.local) and fill in your values.
# NEVER commit the filled-in copy to source control.

# ── Express server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Firebase client-side SDK (used by Vite / the browser bundle) ────────────
# Get these from: Firebase Console → Project Settings → Your apps → SDK setup
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ── Firebase Admin SDK (used by the server only) ────────────────────────────
# Get these from: Firebase Console → Project Settings → Service Accounts →
#   "Generate new private key" (downloads serviceAccountKey.json).
# Copy the values below from that file – do NOT commit the JSON file itself.
#
# IMPORTANT: paste FIREBASE_PRIVATE_KEY with the literal characters \n (backslash-n)
# to represent newlines, e.g.:
#   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBg...\n-----END PRIVATE KEY-----\n"
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
